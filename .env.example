# TemporalGuard-RAG Environment Configuration
# Copy this file to .env and fill in your values

# ═══════════════════════════════════════════════════════════════
# API Keys (Required)
# ═══════════════════════════════════════════════════════════════

# OpenAI API key for LLM access
OPENAI_API_KEY=your_openai_api_key_here

# Email for SEC EDGAR API (required for downloads)
SEC_API_EMAIL=your_email@example.com

# ═══════════════════════════════════════════════════════════════
# Model Configuration
# ═══════════════════════════════════════════════════════════════

# OpenAI model for agents (gpt-4, gpt-4-turbo-preview, gpt-3.5-turbo)
LLM_MODEL=gpt-4

# Embedding model (HuggingFace model name)
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# Embedding dimension (must match model)
EMBEDDING_DIMENSION=768

# ═══════════════════════════════════════════════════════════════
# Processing Configuration
# ═══════════════════════════════════════════════════════════════

# Text chunking settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Retrieval settings
RETRIEVAL_TOP_K=5

# ═══════════════════════════════════════════════════════════════
# Temporal Settings
# ═══════════════════════════════════════════════════════════════

# Filing lag in days (how long after period end before filing is available)
FILING_LAG_10K=60
FILING_LAG_10Q=40
FILING_LAG_8K=4

# ═══════════════════════════════════════════════════════════════
# Security Settings
# ═══════════════════════════════════════════════════════════════

# Enable audit logging
ENABLE_AUDIT_LOGGING=true

# Audit log retention (days)
AUDIT_RETENTION_DAYS=90

# Enable data poisoning detection
ENABLE_POISONING_DETECTION=true

# ═══════════════════════════════════════════════════════════════
# Server Settings
# ═══════════════════════════════════════════════════════════════

# API server
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit
STREAMLIT_PORT=8501

# Debug mode (set to true for development)
DEBUG=false
